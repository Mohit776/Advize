rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // OTP VERIFICATIONS: Server-only (Cloud Functions use Admin SDK)
    match /otpVerifications/{uid} {
      allow read, write: if false;
    }
  
  
  // EXPLORE VIDEOS
    match /exploreVideos/{videoId} {
      allow read: if true;
      allow write: if true;
    }
    

   // USERS: Authenticated users can read profiles (for name/avatar)
match /users/{userId}/{document=**} {
  allow read: if request.auth != null;
  allow write: if request.auth.uid == userId;
}

// NOTIFICATIONS: Allow any authenticated user to create (for cross-user notifications)
match /users/{userId}/notifications/{notificationId} {
  allow read: if request.auth != null;
  allow create: if request.auth != null; // Allow businesses to create notifications for creators
  allow update, delete: if request.auth.uid == userId; // Only owner can modify/delete
}

   match /campaigns/{campaignId} {
  allow read: if true;
  // Business owner can do anything
  allow create, delete: if request.auth.uid == request.resource.data.businessId;
  // Update: business owner OR creator adding themselves to creatorIds
  allow update: if request.auth.uid == resource.data.businessId
                || (request.auth.uid in request.resource.data.creatorIds);
}

    // SUBMISSIONS: Get/List access controlled by ownership
    match /submissions/{submissionId} {
       // GET (single doc): Allow if user is creator or business owner of the campaign.
       allow get: if request.auth.uid == resource.data.creatorId || request.auth.uid == resource.data.businessId;

       // LIST (collection query): Allow if authenticated.
       // Client must constrain query with .where('creatorId','==',uid) or .where('businessId','==',uid)
       allow list: if request.auth != null;

       // CREATE: Creator must match auth'd user and businessId must be present
       allow create: if request.resource.data.creatorId == request.auth.uid && 'businessId' in request.resource.data;
       
       // UPDATE: Business owner can update (approve/reject), Creator can update (submit postUrl)
       allow update: if request.auth.uid == resource.data.businessId || request.auth.uid == resource.data.creatorId;
    }
    
    // REVIEWS: Public read for approved, auth'd write
    match /reviews/{reviewId} {
      allow read: if resource.data.isApproved == true;
      allow create: if request.auth != null;
    }
    
   // GROUPS & MESSAGES: Members/admin only
match /groups/{groupId} {
  // Read: user is admin or member
  allow read: if request.auth.uid == resource.data.adminId || request.auth.uid in resource.data.memberIds;
  
  // Create: user must be setting themselves as admin
  allow create: if request.auth.uid == request.resource.data.adminId;
  
  // Update/Delete: user is currently admin or member
  allow update, delete: if request.auth.uid == resource.data.adminId || request.auth.uid in resource.data.memberIds;

  // Messages subcollection
  match /messages/{messageId} {
    allow read, write: if request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.adminId 
                       || request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
  }
}

    // TRANSACTIONS: Owner only
    match /transactions/{transactionId} {
      // Allow user to read/write their own transaction documents.
      // The 'read' rule covers 'list' queries, which must be constrained with
      // a `where('userId', '==', request.auth.uid)` clause on the client.
      allow read, write: if request.auth.uid == resource.data.userId;
    }

match /earnings/{earningId} {
    allow read: if request.auth.uid == resource.data.creatorId || request.auth.uid == resource.data.businessId;
    
    // Create: Business creating payout OR Creator? (Usually businesses create payouts)
    allow create: if request.auth.uid == request.resource.data.businessId || request.auth.uid == request.resource.data.creatorId;
    
    // Update/Delete: Usually shouldn't happen, but restrict to owner/business
    allow update, delete: if request.auth.uid == resource.data.businessId;
}

// INSTAGRAM AUTO-DM RULES: Owner only
match /instagram_rules/{ruleId} {
  // Read/List: authenticated user whose UID matches the rule's creator_id
  allow read: if request.auth != null && resource.data.creator_id == request.auth.uid;

  // Create: user must be setting creator_id to their own UID
  allow create: if request.auth != null && request.resource.data.creator_id == request.auth.uid;

  // Update/Delete: owner only
  allow update, delete: if request.auth != null && resource.data.creator_id == request.auth.uid;
}

// INSTAGRAM AUTO-DM LOGS: Server writes, owner reads (for analytics)
match /instagram_dm_logs/{logId} {
  allow read: if request.auth != null && resource.data.creator_id == request.auth.uid;
  allow write: if false; // Only written by server-side webhook via Admin SDK
}

// INSTAGRAM CONNECTED ACCOUNTS: Owner only
match /instagram_accounts/{uid} {
  // Only the owner can read/write their own connected account record
  allow read: if request.auth != null && request.auth.uid == uid;
  // Write (create/update) is performed server-side via Admin SDK — deny client writes
  allow write: if false;
  // Allow delete so the user can disconnect from the client
  allow delete: if request.auth != null && request.auth.uid == uid;
}

  }
}
